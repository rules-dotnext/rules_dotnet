startup --windows_enable_symlinks
common --enable_runfiles
common --incompatible_strict_action_env
common --test_output=errors

# Profiling flags — activate with: bazel build //... --config=profile
build:profile --noslim_profile
build:profile --experimental_profile_include_target_label
build:profile --experimental_profile_include_primary_output
build:profile --experimental_collect_load_average_in_profiler
build:profile --experimental_collect_system_network_usage
build:profile --experimental_collect_worker_data_in_profiler

# Enable bzlmod lockfile for reproducible builds (consistent with rules_go, Bazel guidance)
common --lockfile_mode=update

# Verbose failure output
common --verbose_failures

# Remote execution — activate with --config=remote
# Set your endpoint and credentials in .bazelrc.user:
#   build:remote --remote_executor=grpcs://your-remote-executor:port
#   build:remote --remote_cache=grpcs://your-remote-cache:port
#   build:remote --remote_header=<auth-header>=<value>
build:remote --jobs=50
build:remote --remote_timeout=600
# .NET SDK native binaries (libhostpolicy.so, libcoreclr.so) require glibc 2.27+
# and GLIBCXX_3.4.22+. The runtime-deps image provides these uniformly so RE
# workers don't need host-level .NET prerequisites.
build:remote --remote_default_exec_properties=container-image=docker://mcr.microsoft.com/dotnet/runtime-deps:8.0
# Use hermetic Python bootstrap for py_binary tools (e.g. rules_pkg build_tar)
# so they don't depend on /usr/bin/env python3 on the remote executor.
build:remote --@rules_python//python/config_settings:bootstrap_impl=script

# Load any settings specific to the current user.
# .bazelrc.user should appear in .gitignore so that settings are not shared with team members
# This needs to be last statement in this
# config, as the user configuration should be able to overwrite flags from this file.
# See https://docs.bazel.build/versions/master/best-practices.html#bazelrc
# (Note that we use .bazelrc.user so the file appears next to .bazelrc in directory listing,
# rather than user.bazelrc as suggested in the Bazel docs)
try-import %workspace%/.bazelrc.user

# Bazel 8 flags that will be flipped
common --incompatible_disallow_empty_glob
