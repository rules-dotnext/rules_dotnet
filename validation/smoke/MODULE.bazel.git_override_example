"Example: consuming rules_dotnet via git_override"

module(
    name = "my_dotnet_project",
    version = "0.0.0",
)

bazel_dep(name = "rules_dotnet", version = "0.0.0")
git_override(
    module_name = "rules_dotnet",
    remote = "https://github.com/clolin/rules-dotnet-plus.git",
    branch = "release/parity",
)

dotnet = use_extension("@rules_dotnet//dotnet:extensions.bzl", "dotnet")
dotnet.toolchain(dotnet_version = "10.0.100")
use_repo(dotnet, "dotnet_toolchains")

register_toolchains("@dotnet_toolchains//:all")
