load("@rules_dotnet//dotnet:defs.bzl", "csharp_library")

# Phase 2 validation: Spectre.Console
# Building source generator + Spectre.Console.Ansi for net8.0

csharp_library(
    name = "spectre_console_source_generator",
    srcs = glob(
        ["src/src/Spectre.Console.SourceGenerator/**/*.cs"],
        exclude = ["**/Generated/**", "**/obj/**", "**/bin/**"],
    ),
    target_frameworks = ["netstandard2.0"],
    version = "1.0.0",
    is_analyzer = True,
    is_language_specific_analyzer = True,
    deps = [
        "@nuget//microsoft.codeanalysis.analyzers",
        "@nuget//microsoft.codeanalysis.csharp",
        "@nuget//microsoft.codeanalysis.common",
        "@nuget//system.text.json",
        "@nuget//system.collections.immutable",
        "@nuget//system.reflection.metadata",
        "@nuget//isexternalinit",
    ],
)

csharp_library(
    name = "spectre_console_ansi",
    srcs = glob(
        ["src/src/Spectre.Console.Ansi/**/*.cs"],
        exclude = ["**/Generated/**", "**/obj/**", "**/bin/**"],
    ),
    target_frameworks = ["net8.0"],
    version = "1.0.0",
    defines = ["TRACE", "WCWIDTH", "WCWIDTH_VISIBILITY_INTERNAL"],
    data = ["src/src/Spectre.Console.Ansi/Data/colors.json"],
    deps = [
        ":spectre_console_source_generator",
    ],
)
