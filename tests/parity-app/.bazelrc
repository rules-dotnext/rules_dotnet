# Hermetic build configuration for parity-app
# Bazel 8 LTS — bzlmod is default, WORKSPACE is disabled by default

# Strict environment — no host leakage
build --incompatible_strict_action_env

# Automatic exec groups — spec-bazel-compat #457
build --incompatible_auto_exec_groups

# Lockfile for reproducible resolution
common --lockfile_mode=update

# Global Roslyn analyzer enforcement — spec-static-analysis parity
# DISABLED until spec-static-analysis creates the label_flag at this path.
# Uncomment after implementing dotnet/private/rules/analysis/BUILD.bazel:
# build --@rules_dotnet//dotnet/private/rules/analysis:analysis_config=//:analysis_config

# Test output for debugging
test --test_output=errors

# Coverage support — spec-testing-infra #359
coverage --combined_report=lcov

# Agent-optimized settings (verbose output, keep_going, timestamps)
try-import .bazelrc.agent
