# Agent-optimized Bazel settings — import from .bazelrc via try-import
# Usage: add `try-import .bazelrc.agent` to .bazelrc

# Continue building after first error to surface all failures at once
build --keep_going

# Colored output for readable error messages
common --color=yes

# Show all test output, not just failures — agents need full context
test --test_output=all

# Verbose failures with full command lines for debugging
build --verbose_failures

# Show timestamps in output for correlating with agent logs
common --show_timestamps

# Subcommand printing — shows exact compiler invocations
# Uncomment when debugging action construction:
# build --subcommands=pretty_print

# Disk cache for faster rebuilds during iterative development
# build --disk_cache=~/.cache/bazel-parity-app

# Analysis testing support
test --test_tag_filters=-manual
