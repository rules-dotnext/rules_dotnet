"""spec-quick-wins targets — version attribute, $(location) expansion.

These targets use attributes added by spec-quick-wins (#423, #524).
They will fail to load until the spec is implemented in rules_dotnet.
"""

load("@bazel_skylib//rules:build_test.bzl", "build_test")
load("@rules_dotnet//dotnet:defs.bzl", "csharp_library")

# --- #423: version attribute ---
# BEFORE FIX: no such attribute 'version' in 'csharp_library' rule
csharp_library(
    name = "versioned_lib",
    srcs = ["//:Greeter.cs"],
    target_frameworks = ["net8.0"],
    version = "2.1.0",
    visibility = ["//visibility:public"],
)

# --- #524: $(location) expansion in compiler_options ---
# BEFORE FIX: $(location) is not expanded
csharp_library(
    name = "location_expansion",
    srcs = ["//:Greeter.cs"],
    compile_data = ["//:doc.xml"],
    compiler_options = ["/additionalfile:$(location //:doc.xml)"],
    target_frameworks = ["net8.0"],
)

# --- #442: treat_warnings_as_errors ---
# BEFORE FIX: no such attribute 'treat_warnings_as_errors' in 'csharp_library'
csharp_library(
    name = "warnings_as_errors",
    srcs = ["//:Clean.cs"],
    target_frameworks = ["net8.0"],
    treat_warnings_as_errors = True,
)

# --- #519: generate_documentation_file ---
# BEFORE FIX: no such attribute 'generate_documentation_file' in 'csharp_library'
csharp_library(
    name = "with_docs",
    srcs = ["//:Greeter.cs"],
    generate_documentation_file = True,
    target_frameworks = ["net8.0"],
)

build_test(
    name = "build_test",
    targets = [
        ":versioned_lib",
        ":location_expansion",
        ":warnings_as_errors",
        ":with_docs",
    ],
)
