"""Parity test app for rules_dotnet.

This workspace exercises every feature gap identified in the rules_dotnet
maturity plan. When `bazel test //...` passes, rules_dotnet has achieved
parity with rules_cc, rules_go, and rules_py for their respective languages.

Each BUILD target is annotated with the spec and issue(s) it validates.
Agents implementing a spec should make their corresponding targets build.
"""

module(
    name = "parity_app",
    version = "0.0.0",
)

# --- rules_dotnet (local development copy) ---
# AGENT: Change this path to your isolated clone directory.
# Example: path = "/home/colin/agent-quick-wins"
bazel_dep(name = "rules_dotnet", version = "0.0.0")
local_path_override(
    module_name = "rules_dotnet",
    path = "../..",  # rules_dotnet root (2 levels up from tests/parity-app)
)

# --- Toolchain: .NET 8 SDK (LTS) ---
dotnet = use_extension("@rules_dotnet//dotnet:extensions.bzl", "dotnet")
dotnet.toolchain(dotnet_version = "8.0.303")
use_repo(dotnet, "dotnet_toolchains")

register_toolchains("@dotnet_toolchains//:all")

# --- Native code support (spec-native-interop) ---
bazel_dep(name = "rules_cc", version = "0.1.1")

# --- Proto/gRPC support (spec-proto-grpc) ---
bazel_dep(name = "rules_proto", version = "7.1.0")
bazel_dep(name = "protobuf", version = "29.3")

# --- Build validation ---
bazel_dep(name = "bazel_skylib", version = "1.7.1")

# --- NuGet packages ---
# In a real project these are generated by paket2bazel.
# Hand-written here with the minimum packages needed by the parity app.
parity_nuget = use_extension("//:paket.parity_extension.bzl", "parity_nuget")
use_repo(parity_nuget, "paket.parity")
