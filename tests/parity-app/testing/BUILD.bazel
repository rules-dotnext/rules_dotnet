"""spec-testing-infra targets — NUnit test with coverage + flatten_deps.

Tests flatten_deps, InstrumentedFilesInfo, and NUnit runner (#207, #359, #450).
Uses its own library dep to avoid cross-spec dependency on quick-wins.
"""

load("@rules_dotnet//dotnet:defs.bzl", "csharp_library", "csharp_nunit_test")

# Standalone library for testing (no spec-specific attrs)
csharp_library(
    name = "test_lib",
    srcs = ["//:Greeter.cs"],
    target_frameworks = ["net8.0"],
)

# --- #207, #359, #450: NUnit test with coverage + flatten ---
# BEFORE FIX: no such attribute 'flatten_deps' in 'csharp_nunit_test' rule;
#   bazel coverage fails (no InstrumentedFilesInfo / _lcov_merger)
# Uses default NUnit/NUnitLite from label_flags (rules_dotnet internal packages).
csharp_nunit_test(
    name = "greeter_test",
    srcs = ["//:GreeterTest.cs"],
    flatten_deps = True,
    target_frameworks = ["net8.0"],
    deps = [
        ":test_lib",
    ],
)
